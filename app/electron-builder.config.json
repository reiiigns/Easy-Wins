{
  "appId": "com.easywinstracker.app",
  "productName": "Easy Wins",
  "copyright": "Easy Wins Project Tracker",
  "directories": {
    "output": "release",
    "buildResources": "assets"
  },
  "asar": false,
  "files": [
    "dist/**/*",
    "assets/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "models",
      "to": "models",
      "filter": ["**/*.gguf"]
    },
    {
      "from": "tools",
      "to": "tools"
    }
  ],
  "win": {
    "target": [
      { "target": "nsis", "arch": ["x64"] }
    ],
    "icon": "assets/icon.ico"
  },
  "mac": {
    "target": [
      { "target": "dmg", "arch": ["x64", "arm64"] },
      { "target": "zip", "arch": ["x64", "arm64"] }
    ],
    "icon": "assets/icon.icns",
    "hardenedRuntime": true,
    "gatekeeperAssess": false
  },
  "linux": {
    "target": [
      { "target": "AppImage", "arch": ["x64"] },
      { "target": "deb", "arch": ["x64"] }
    ],
    "icon": "assets/icon.png",
    "category": "Development"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "runAfterFinish": true,
    "shortcutName": "Easy Wins"
  }
}
