# Analyzer provider: auto, local, openai, or heuristics
ANALYZER_PROVIDER=auto

# Local offline llama.cpp provider
LOCAL_LLM_ENABLED=true
LLAMA_CPP_SERVER_PATH=C:\path\to\llama-server.exe
LOCAL_LLM_MODEL_PATH=C:\path\to\model.gguf
LOCAL_LLM_MODEL_NAME=local-llama-cpp
LOCAL_LLM_HOST=127.0.0.1
LOCAL_LLM_PORT=8081
LOCAL_LLM_CTX_SIZE=4096
LOCAL_LLM_TIMEOUT_MS=90000
LOCAL_LLM_STARTUP_TIMEOUT_MS=120000
LOCAL_LLM_MAX_TOKENS=2200
LOCAL_LLM_TEMPERATURE=0.1

# Optional review knowledge base loaded from curated SKILL.md files
ANALYZER_SKILLS_ENABLED=true
ANALYZER_SKILLS_PATH=\\wsl.localhost\Ubuntu\home\dair\.hermes\skills
ANALYZER_SKILLS_ALLOWLIST=github/github-code-review/SKILL.md,github/codebase-inspection/SKILL.md,creative/open-design-reviewer/SKILL.md,creative/open-design/SKILL.md,creative/design-md/SKILL.md,creative/popular-web-designs/SKILL.md,creative/claude-design/SKILL.md,research/deep-dive-research-synthesis/SKILL.md
ANALYZER_SKILLS_MAX_CHARS=3200

# OpenAI API Key (optional fallback when ANALYZER_PROVIDER is auto or openai)
OPENAI_API_KEY=your_openai_api_key_here

# Server port (optional, defaults to 3001)
PORT=3001

# Node environment
NODE_ENV=development
